PORT=3200
HOST=127.0.0.1

DATABASE_URL=postgres://chart:chart@127.0.0.1:5432/chart
CHART_SOLUTION_REPOSITORY_URL=
CHART_SOLUTION_REPOSITORY_SNAPSHOT_FILE=

KEYCLOAK_ISSUER_URL=http://127.0.0.1:8080/realms/chart
KEYCLOAK_CLIENT_ID=chart-api
KEYCLOAK_JWKS_URL=http://127.0.0.1:8080/realms/chart/protocol/openid-connect/certs
KEYCLOAK_CLOCK_SKEW_SECONDS=30

# DHIS2 health data source. Use a dedicated read-only DHIS2 service user.
DHIS2_BASE_URL=
DHIS2_API_VERSION=41
DHIS2_AUTH_MODE=pat
DHIS2_API_TOKEN=

# Alternative DHIS2 auth modes, only if a deployment cannot use PAT.
DHIS2_USERNAME=
DHIS2_PASSWORD=
DHIS2_BEARER_TOKEN=
