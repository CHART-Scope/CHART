PORT=3000
HOST=127.0.0.1

# Use "demo" for local API-only work and tests.
# Use "keycloak" when the API should verify bearer tokens from Keycloak.
CHART_AUTH_MODE=demo

DATABASE_URL=postgres://chart:chart@127.0.0.1:5432/chart_app

KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/chart
KEYCLOAK_CLIENT_ID=chart-api
KEYCLOAK_JWKS_URL=http://localhost:8080/realms/chart/protocol/openid-connect/certs
KEYCLOAK_CLOCK_SKEW_SECONDS=30
