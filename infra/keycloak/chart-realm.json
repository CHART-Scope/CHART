{
  "realm": "chart",
  "enabled": true,
  "displayName": "CHART",
  "sslRequired": "none",
  "loginTheme": "chart",
  "roles": {
    "realm": [
      {
        "name": "offline_access"
      },
      {
        "name": "uma_authorization"
      }
    ],
    "client": {
      "chart-api": [
        {
          "name": "u1_health_lead",
          "description": "State or county health lead"
        },
        {
          "name": "u2_cross_sector_lead",
          "description": "State or county cross-sector lead"
        },
        {
          "name": "u3_district_health_officer",
          "description": "District or sub-county health officer"
        },
        {
          "name": "u4_district_cross_sector_officer",
          "description": "District or sub-county cross-sector officer"
        },
        {
          "name": "u5_public_visitor",
          "description": "Public visitor or partner"
        },
        {
          "name": "chart_admin",
          "description": "CHART administrator"
        },
        {
          "name": "content_editor",
          "description": "Can manage CHART public content and solution repository records"
        }
      ]
    }
  },
  "groups": [
    {
      "name": "country-a",
      "attributes": {
        "country_code": ["CTA"],
        "geo_level": ["country"]
      },
      "subGroups": [
        {
          "name": "region-a",
          "attributes": {
            "country_code": ["CTA"],
            "geo_level": ["geo_level_1"],
            "level_label": ["region"]
          },
          "subGroups": [
            {
              "name": "district-a",
              "attributes": {
                "country_code": ["CTA"],
                "geo_level": ["geo_level_2"],
                "level_label": ["district"]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "country-b",
      "attributes": {
        "country_code": ["CTB"],
        "geo_level": ["country"]
      },
      "subGroups": [
        {
          "name": "region-b",
          "attributes": {
            "country_code": ["CTB"],
            "geo_level": ["geo_level_1"],
            "level_label": ["region"]
          },
          "subGroups": [
            {
              "name": "district-c",
              "attributes": {
                "country_code": ["CTB"],
                "geo_level": ["geo_level_2"],
                "level_label": ["district"]
              }
            }
          ]
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "chart-web",
      "name": "CHART web",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "fullScopeAllowed": true,
      "redirectUris": ["http://localhost:3100/*", "http://127.0.0.1:3100/*"],
      "webOrigins": ["+"],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:3100##http://localhost:3100/*##http://127.0.0.1:3100##http://127.0.0.1:3100/*"
      },
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "groups",
            "full.path": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "chart-api",
      "name": "CHART API",
      "enabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true
    }
  ],
  "users": [
    {
      "username": "chart-admin",
      "enabled": true,
      "email": "chart-admin@example.org",
      "firstName": "CHART",
      "lastName": "Admin",
      "groups": ["/country-a"],
      "clientRoles": {
        "chart-api": ["chart_admin", "content_editor"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ]
    },
    {
      "username": "u1-health-region",
      "enabled": true,
      "email": "u1-health-region@example.org",
      "firstName": "U1",
      "lastName": "Health Region",
      "groups": ["/country-a/region-a"],
      "clientRoles": {
        "chart-api": ["u1_health_lead"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ]
    },
    {
      "username": "u2-sector-region",
      "enabled": true,
      "email": "u2-sector-region@example.org",
      "firstName": "U2",
      "lastName": "Sector Region",
      "groups": ["/country-b/region-b"],
      "clientRoles": {
        "chart-api": ["u2_cross_sector_lead"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ]
    },
    {
      "username": "u3-health-district",
      "enabled": true,
      "email": "u3-health-district@example.org",
      "firstName": "U3",
      "lastName": "Health District",
      "groups": ["/country-a/region-a/district-a"],
      "clientRoles": {
        "chart-api": ["u3_district_health_officer"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ]
    },
    {
      "username": "u4-sector-district",
      "enabled": true,
      "email": "u4-sector-district@example.org",
      "firstName": "U4",
      "lastName": "Sector District",
      "groups": ["/country-b/region-b/district-c"],
      "clientRoles": {
        "chart-api": ["u4_district_cross_sector_officer"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ]
    }
  ]
}
